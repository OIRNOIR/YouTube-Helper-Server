enum Platform {
	YouTube
	PeerTube
}

enum VideoType {
	video
	short
	stream
}

enum SponsorBlockStatus {
	sponsor
	selfpromo
	exclusive_access
}

enum VideoAvailability {
	private
	premium_only
	subscriber_only
	needs_auth
	unlisted
	public
	upcoming_stream
	processing
}

model Video {
	videoId String @id @unique
	platform String
	type VideoType
	title String
	description String?
	duration Int?
	displayName String
	username String
	channelId String
	date DateTime
	releaseDate DateTime?
	isCurrentlyLive Boolean
	unread Boolean @default(true)
	sponsorBlockStatus SponsorBlockStatus?
	url String
	availability VideoAvailability
}
